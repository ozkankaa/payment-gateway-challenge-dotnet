{
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://localhost:7001",
        "Protocols": "Http1AndHttp2"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "https://localhost:3000" ]
  },
  "ConnectionStrings": {
    "PaymentDb": "Data Source=payment-gateway.db",
    "PaymentSagaDb": "Data Source=payment-event.db"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "payment-integration-events",
    "QueueName": "payment-integration-events-queue",
    "RoutingKey": "payment.integration-event",
    "PrefetchCount": 10
  },
  "Service": {
    "Name": "payment-service",
    "Version": "1.0.0",
    "Environment": "local",
    "OutputCache": {
      "DurationSeconds": 60,
      "Tag": "payments",
      "VaryByQuery": [ "completed" ]
    },
    "RateLimit": {
      "PermitLimit": 80,
      "WindowSeconds": 60,
      "QueueLimit": 20,
      "QueueProcessing": "OldestFirst"
    },
    "OpenTelemetry": {
      "OtlpEndpoint": "http://localhost:4318",
      "Protocol": "HttpProtobuf"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Expressions",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread",
      "Serilog.Enrichers.Span"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.AspNetCore.Routing": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithSpan"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] [TraceId: {TraceId}] [CorrelationId: {CorrelationId}] {Message:lj}{NewLine}{Exception}"
          //"formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
          //"formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
          //"formatter": {
          //  "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
          //  "template": "{ {@t: @t, level: @l, message: @m, trace_id: TraceId, span_id: SpanId, parent_id: ParentId, correlation_id: correlation_id, payment_id: payment_id, merchant_id: merchant_id, status: status, psp_reference: psp_reference, error_code: error_code, error_message: error_message, service_name: service_name, environment: environment, machine_name: MachineName, thread_id: ThreadId, source_context: SourceContext} }\n"
          //}
        }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "endpoint": "http://localhost:4318/v1/logs",
          "protocol": "HttpProtobuf",
          "resourceAttributes": {
            "service.name": "payment-service",
            "service.version": "1.0.0",
            "deployment.environment": "local"
          }
        }
      }
    ],
    "Properties": {
      "service_name": "payment-service",
      "environment": "local"
    }
  },
  "AcquiringBank": {
    "BaseUrl": "http://localhost:8080",
    //"BaseUrl": "https://psp-provider",
    "MaxRetryAttempts": 3,
    "TimeoutSeconds": 5
  },
  "FraudService": {
    "BaseUrl": "http://localhost:8086",
    //"BaseUrl": "https://fraud-service",
    "MaxRetryAttempts": 3,
    "TimeoutSeconds": 5
  }
}
