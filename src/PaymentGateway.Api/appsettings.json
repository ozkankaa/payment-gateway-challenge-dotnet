{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "https://localhost:3000" ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "WriteTo": [ { "Name": "Console" } ]
  },
  "AcquiringBank": {
    "BaseUrl": "http://localhost:8080",
    "MaxRetryAttempts": 3,
    "TimeoutSeconds": 5
  },
  "PaymentsRateLimit": {
    "PermitLimit": 80,
    "WindowSeconds": 60,
    "QueueLimit": 20,
    "QueueProcessing": "OldestFirst"
  },
  "PaymentsCache": {
    "DurationSeconds": 60,
    "Tag": "payments",
    "VaryByQuery": [ "completed" ]
  }
}
