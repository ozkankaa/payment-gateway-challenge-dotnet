{
  "family": "payment-gateway-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [ "FARGATE" ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/paymentGatewayApiTaskRole",
  "containerDefinitions": [
    {
      "name": "payment-gateway-api",
      "image": "placeholder",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Production"
        },
        {
          "name": "Service__Name",
          "value": "payment-service"
        },
        {
          "name": "Service__Version",
          "value": "1.0.0"
        },
        {
          "name": "Service__Environment",
          "value": "production"
        },
        {
          "name": "Service__OutputCache__DurationSeconds",
          "value": "60"
        },
        {
          "name": "Service__OutputCache__Tag",
          "value": "payments"
        },
        {
          "name": "Service__RateLimit__PermitLimit",
          "value": "80"
        },
        {
          "name": "Service__RateLimit__WindowSeconds",
          "value": "60"
        },
        {
          "name": "Service__RateLimit__QueueLimit",
          "value": "20"
        },
        {
          "name": "Service__RateLimit__QueueProcessing",
          "value": "OldestFirst"
        },
        {
          "name": "RabbitMq__Port",
          "value": "5672"
        },
        {
          "name": "RabbitMq__VirtualHost",
          "value": "/"
        },
        {
          "name": "RabbitMq__ExchangeName",
          "value": "payment-domain-events"
        },
        {
          "name": "RabbitMq__QueueName",
          "value": "payment-domain-events-queue"
        },
        {
          "name": "RabbitMq__RoutingKey",
          "value": "payment.domain-event"
        },
        {
          "name": "RabbitMq__PrefetchCount",
          "value": "10"
        }
      ],
      "secrets": [
        {
          "name": "ConnectionStrings__PaymentDb",
          "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/payment-gateway/prod/payment-db"
        },
        {
          "name": "RabbitMq__HostName",
          "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/payment-gateway/prod/rabbitmq-host"
        },
        {
          "name": "RabbitMq__UserName",
          "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/payment-gateway/prod/rabbitmq-username"
        },
        {
          "name": "RabbitMq__Password",
          "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/payment-gateway/prod/rabbitmq-password"
        },
        {
          "name": "AcquiringBank__BaseUrl",
          "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/payment-gateway/prod/acquiring-bank-base-url"
        },
        {
          "name": "FraudService__BaseUrl",
          "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/payment-gateway/prod/fraud-service-base-url"
        },
        {
          "name": "Service__OpenTelemetry__OtlpEndpoint",
          "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/payment-gateway/prod/otlp-endpoint"
        },
        {
          "name": "Serilog__WriteTo__1__Args__endpoint",
          "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/payment-gateway/prod/otlp-logs-endpoint"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8080/health/ready || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/payment-gateway-api",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "api"
        }
      }
    }
  ]
}